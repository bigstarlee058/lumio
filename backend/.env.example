# Lumio backend environment variables
# Development mode works without this file.
# Full reference: backend/.env.all-options

# Core settings (defaults shown):
# PORT=3001
# NODE_ENV=development
# FRONTEND_URL=http://localhost:3000
# APP_URL=http://localhost:3000
# DATABASE_URL=postgresql://finflow:finflow@localhost:5432/finflow
# REDIS_URL=redis://localhost:6379

# Required in production only:
# JWT_SECRET=<run: openssl rand -base64 32>
# JWT_REFRESH_SECRET=<run: openssl rand -base64 32>
# INTEGRATIONS_ENCRYPTION_KEY=<run: openssl rand -base64 32>

# Required when Telegram webhook integration is enabled:
# TELEGRAM_WEBHOOK_SECRET=<run: openssl rand -base64 32>

# Optional auth settings:
# JWT_EXPIRES_IN=30d
# JWT_REFRESH_EXPIRES_IN=30d

# Optional logging:
# LOG_LEVEL=info
# SERVICE_NAME=finflow-backend
