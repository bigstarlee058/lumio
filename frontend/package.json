    "framer-motion": "^12.34.3",
    "intlayer": "^7.5.11",
    "next": "^16.1.2",
    "next-intlayer": "^7.5.11",
    "next-themes": "^0.2.1",
    "react": "19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-intlayer": "^7.5.11",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.3.0",
