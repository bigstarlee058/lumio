{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "intlayer build",
    "prebuild": "intlayer build",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "npm run lint:check",
    "lint:check": "biome check --config-path=.. . && eslint .",
    "lint:fix": "biome check --config-path=.. --write . && eslint --fix .",
    "lint:eslint": "eslint .",
    "lint:biome": "biome check --config-path=.. .",
    "format": "biome format --config-path=.. --write .",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:profile": "vitest run app/settings/profile/page.test.tsx",
    "lint:css": "stylelint \"app/styles/**/*.scss\" \"app/components/**/*.scss\""
  },
  "dependencies": {
