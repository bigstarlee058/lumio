{
  "name": "parse-ledger",
  "version": "1.0.0",
  "description": "Lumio - Bank statements processing system",
  "main": "backend/dist/main.js",
  "scripts": {
    "prepare": "husky",
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "build": "npm --prefix frontend run build && npm --prefix backend run build",
    "start": "node backend/dist/main.js",
    "dev": "concurrently \"npm --prefix backend run start:dev\" \"npm --prefix frontend run dev\"",
    "backend:build": "npm --prefix backend run build",
    "backend:start": "npm --prefix backend run start",
    "backend:dev": "npm --prefix backend run start:dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "frontend:dev": "npm --prefix frontend run dev",
    "migration:run": "npm --prefix backend run migration:run",
    "migration:generate": "npm --prefix backend run migration:generate",
    "create-admin": "npm --prefix backend run create-admin",
    "knip": "knip",
    "electron:dev": "concurrently \"npm --prefix frontend run dev\" \"npm --prefix electron run dev\"",
    "electron:build": "npm --prefix electron run build",
    "electron:build:mac": "npm --prefix electron run build:mac",
    "electron:build:win": "npm --prefix electron run build:win",
    "electron:build:linux": "npm --prefix electron run build:linux"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^25.5.0",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "typescript": "^6.0.2"
  }
}
