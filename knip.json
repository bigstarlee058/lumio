  "workspaces": {
    ".": {
      "entry": [
        "package.json"
      ],
      "project": [
        "*.{js,ts,json}"
      ]
    },
    "backend": {
      "entry": [
        "src/main.ts",
        "src/data-source.ts",
        "scripts/**/*.{ts,js}",
        "@tests/**/*.ts",
        "jest*.{js,ts}",
        "babel.config.js"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{ts,js}",
        "@tests/**/*.{ts,tsx}",
        "*.{js,ts}"
      ],
      "ignoreDependencies": [
        "swagger-ui-express"
      ]
    },
    "frontend": {
      "entry": [
        "app/**/*.{ts,tsx}",
        "app/**/*.css",
        ".storybook/**/*.{js,ts,tsx}",
        "next.config.*",
        "middleware.ts",
        "types/**/*.d.ts"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "hooks/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "shared/**/*.{ts,tsx}",
        "contexts/**/*.{ts,tsx}",
        "providers/**/*.{ts,tsx}",
        "services/**/*.{ts,tsx}",
        "types/**/*.{ts,tsx,d.ts}",
        "app/**/*.css",
        ".storybook/**/*.{js,ts,tsx}",
        "*.{js,ts,mjs}"
      ],
      "storybook": {
        "config": [
          ".storybook/main.ts"
        ]
      },
      "webpack": {
        "config": [
          ".storybook/main.ts"
        ]
      },
      "babel": {
        "config": [
          ".storybook/main.ts"
        ]
      },
      "postcss": {
        "config": [
          "postcss.config.mjs"
        ]
      },
      "tailwind": {
        "entry": [
          "app/**/*.css"
        ]
      },
      "ignoreDependencies": [
        "@babel/plugin-transform-runtime",
        "@babel/preset-react",
        "@babel/preset-typescript",
        "babel-loader",
        "ts-loader"
      ]
    },
    "website": {
      "entry": [
        "src/**/*.{ts,tsx,js,jsx}",
        "docusaurus.config.*",
        "sidebars.*"
      ],
      "project": [
        "src/**/*.{ts,tsx,js,jsx}",
        "*.{js,ts,mjs,cjs}"
      ],
      "docusaurus": {
        "config": [
          "docusaurus.config.*",
          "sidebars.*"
        ]
      }
    },
    "react-email-starter": {
      "entry": [
        "emails/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "package.json"
      ],
      "project": [
        "**/*.{ts,tsx,js,jsx}"
      ],
      "ignoreBinaries": [
        "email"
      ],
      "ignoreDependencies": [
        "react",
        "react-dom",
        "react-email",
        "@react-email/preview-server",
        "@types/react",
        "@types/react-dom"
      ]
    }
  },
  "tags": [
    "-lintignore"
  ]
}
