{
  "name": "lumio-desktop",
  "version": "1.0.0",
  "description": "Lumio Desktop — native desktop client",
  "main": "dist/main.js",
  "productName": "Lumio",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:watch": "concurrently \"tsc -w\" \"nodemon --watch dist --exec electron .\"",
    "build:ts": "tsc",
    "build": "tsc && electron-builder",
    "build:mac": "tsc && electron-builder --mac",
    "build:win": "tsc && electron-builder --win",
    "build:linux": "tsc && electron-builder --linux",
    "pack": "tsc && electron-builder --dir"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.9",
    "typescript": "^5.8.3"
  }
}
