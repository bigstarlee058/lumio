{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",

  "files": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.next/**",
      "**/out/**",
      "**/build/**",
      "**/coverage/**",
      "frontend/next-env.d.ts",
      "frontend/.intlayer/**",
      ".intlayer/**",
      "frontend/.next/**",
      "frontend/out/**",
      "backend/uploads/**",
      "**/stories/**",
      "**/storybook-static/**",
      "**/*.stories.*",
      "**/docs/**",
      "**/.claude/**",
      "**/.agent/**",
      "**/*.spec.{ts,tsx}",
      "**/*.test.{ts,tsx}",
      "**/@tests/**",
      "backend/scripts/**"
    ]
  },

  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "organizeImports": {
    "enabled": true
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "asNeeded"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "a11y": {
        "recommended": true,
        "useButtonType": "off",
        "noLabelWithoutControl": "warn",
        "useKeyWithClickEvents": "warn",
        "useValidAriaRole": "warn",
        "noSvgWithoutTitle": "warn",
        "noRedundantRoles": "warn",
        "useSemanticElements": "warn"
      },

      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noForEach": "warn",
        "useFlatMap": "error",
        "useOptionalChain": "error",
        "useSimplifiedLogicExpression": "warn",
        "noUselessTernary": "error",
        "noUselessFragments": "error",
        "noStaticOnlyClass": "error",
        "noUselessCatch": "error",
        "noUselessConstructor": "error"
      },

      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedVariables": "warn",
        "noUnusedImports": "error",
        "noUnusedPrivateClassMembers": "error",
        "noInvalidUseBeforeDeclaration": "error"
      },

      "suspicious": {
        "noExplicitAny": "warn",
        "noDoubleEquals": "error",
        "noImplicitAnyLet": "error",
        "useIsArray": "error",
        "noDebugger": "error",
        "noEmptyBlockStatements": "warn",
        "noDuplicateObjectKeys": "error",
        "noShadowRestrictedNames": "warn",
        "noRedeclare": "warn",
        "noArrayIndexKey": "warn"
      },

      "style": {
        "useImportType": "off",
        "useNodejsImportProtocol": "off",
        "noUnusedTemplateLiteral": "warn",
        "useConst": "error",
        "useBlockStatements": "warn",
        "useDefaultParameterLast": "error",
        "noUselessElse": "error",
        "useShorthandAssign": "warn",
        "useSingleVarDeclarator": "error",
        "useTemplate": "error",
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": true,
            "requireAscii": true,
            "conventions": [
              {
                "selector": { "kind": "typeLike" },
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "enumMember" },
                "formats": ["CONSTANT_CASE"]
              },
              {
                "selector": { "kind": "function" },
                "formats": ["camelCase", "PascalCase"]
              },
              {
                "selector": { "kind": "variable" },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": { "kind": "classProperty" },
                "formats": ["camelCase"]
              },
              {
                "selector": { "kind": "classMethod" },
                "formats": ["camelCase"]
              }
            ]
          }
        }
      },

      "performance": {
        "noDelete": "error",
        "noAccumulatingSpread": "error"
      }
    }
  },

  "overrides": [
    {
      "include": [
        "frontend/**/*.{ts,tsx,js,jsx}",
        "app/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useButtonType": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "warn"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": {
              "level": "warn",
              "options": {
                "maxAllowedComplexity": 15
              }
            },
            "noForEach": "warn",
            "noUselessFragments": "error"
          },
          "suspicious": {
            "noExplicitAny": "warn",
            "noImplicitAnyLet": "error"
          },
          "style": {
            "noUselessElse": "error",
            "useBlockStatements": "warn",
            "useTemplate": "error"
          }
        }
      }
    },

    {
      "include": [
        "**/@tests/**/*.{ts,tsx}",
        "**/test/**/*.{ts,tsx}",
        "**/*.spec.{ts,tsx}",
        "**/*.test.{ts,tsx}",
        "frontend/app/**/*.test.{ts,tsx}",
        "app/**/*.test.{ts,tsx}",
        "**/.storybook/**/*.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noEmptyBlockStatements": "off"
          },
          "style": {
            "useImportType": "off",
            "useNamingConvention": "off",
            "useTemplate": "off"
          },
          "correctness": {
            "noUnusedVariables": "warn"
          },
          "complexity": {
            "noForEach": "off"
          }
        }
      },
      "organizeImports": {
        "enabled": false
      }
    }
  ]
}
